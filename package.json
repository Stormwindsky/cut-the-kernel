{
  "name": "cut-the-kernel",
  "version": "1.0.0",
  "description": "Unofficial Cut the Rope player for Linux",
  "main": "main.js",
  "author": "Stormwindsky",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --linux AppImage"
  },
  "build": {
    "appId": "com.stormwindsky.cutthekernel",
    "productName": "Cut the Kernel",
    "linux": {
      "category": "Game",
      "target": ["AppImage"],
      "icon": "icon.png"
    }
  },
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "latest"
  }
}
